# Docker Compose Environment Variables
# Copy this file to .env and customize the values

# === Container Configuration ===

GITHUB_USERNAME=your_github_username

# Project name — must be unique per container to allow running multiple boxes simultaneously
COMPOSE_PROJECT_NAME=yolo-claudecode

# Container and hostname (required)
CONTAINER_NAME=yolo-claudecode

# Docker image name (optional, defaults to yoloimage)
DOCKER_IMAGE=yoloimage

# Host port to map to container SSH port 22 (optional, defaults to 22222)
HOST_PORT=22222

# Workspace path (optional, defaults to $HOME/workspace/$CONTAINER_NAME)
# WORKSPACE_PATH=/custom/path/to/workspace

# Set to false to skip installing pi-coding-agent and the anthropic-no-timeout extension
INSTALL_PI=true

# === Host user mapping ===
# The container user is remapped to these UID/GID at startup so files written to
# the mounted /workspace stay owned by your host user. If left unset, the entrypoint
# auto-detects from the owner of the /workspace mount. To set explicitly, run:
#   echo "HOST_UID=$(id -u)" >> .env && echo "HOST_GID=$(id -g)" >> .env
# HOST_UID=1000
# HOST_GID=1000

# === LLM Configuration (Simplified) ===

# Single endpoint URL for your LLM server (vLLM, LM Studio, etc.)
# The container will auto-discover available models from {LLM_ENDPOINT}/v1/models
# Examples:
#   LLM_ENDPOINT=http://127.0.0.1:8001        # vLLM
#   LLM_ENDPOINT=http://host.docker.internal:11434  # Ollama (on host)
#
# If not set, a default placeholder config is created that you can edit manually.
LLM_ENDPOINT=http://127.0.0.1:8001

