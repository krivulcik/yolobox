# Docker Compose Environment Variables
# Copy this file to .env and customize the values

GITHUB_USERNAME=your_github_username

# Project name — must be unique per container to allow running multiple boxes simultaneously
COMPOSE_PROJECT_NAME=yolo-claudecode

# Container and hostname (required)
CONTAINER_NAME=yolo-claudecode

# Docker image name (optional, defaults to yoloimage)
DOCKER_IMAGE=yoloimage

# Host port to map to container SSH port 22 (optional, defaults to 22222)
HOST_PORT=22222

# Workspace path (optional, defaults to $HOME/workspace/$CONTAINER_NAME)
# WORKSPACE_PATH=/custom/path/to/workspace

# Set to false to skip installing pi-coding-agent and rendering its models.json
INSTALL_PI=true

# pi-coding-agent models.json — rendered at container start to ~/.pi/agent/models.json (only if INSTALL_PI=true)
# PI_API options: anthropic-messages | openai-completions | openai-responses | google-gemini-cli | openai-codex-responses
PI_PROVIDER=local
PI_BASE_URL=http://localhost:11434
PI_API=anthropic-messages
PI_API_KEY=MY_API_KEY
PI_MODEL_ID=opus
PI_MODEL_NAME=opus
PI_MODEL_REASONING=false
PI_CONTEXT_WINDOW=100000
